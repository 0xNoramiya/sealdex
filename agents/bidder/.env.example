# Bidder agent env vars — copy to .env and fill in.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=

# Recommended: Helius devnet RPC for transaction reliability.
# Sign up at https://helius.dev — free tier is sufficient.
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=

# Required for external bidders: the public auction feed URL.
# Defaults to a local file when unset (only useful when bidding alongside
# the auctioneer on the same host).
SEALDEX_REGISTRY_URL=

# Where the bidder writes its state + stream JSONL. Defaults to <repo>/scripts.
SEALDEX_STATE_DIR=
