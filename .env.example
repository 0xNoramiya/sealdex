# Sealdex environment variables — copy to .env (which is gitignored)

# === Anthropic ===
# Required for the bidder agent (Claude tool-use loop)
ANTHROPIC_API_KEY=

# === Solana / MagicBlock ===
# Base devnet RPC. Helius is recommended for reliability:
#   https://devnet.helius-rpc.com/?api-key=<your-key>
SOLANA_RPC_URL=https://api.devnet.solana.com

# MagicBlock devnet TEE Ephemeral Rollup endpoint
EPHEMERAL_RPC_URL=https://devnet-tee.magicblock.app

# TEE validator pubkey — required when delegating accounts. Defaults to the
# devnet validator if unset; override only if MagicBlock spins a new one.
# TEE_VALIDATOR_PUBKEY=MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo

# Sealdex program. Defaults to the deployed devnet ID; only override if you
# redeploy under a different program ID.
# SEALDEX_PROGRAM_ID=4DBEkkdMaW7boAsmEFXLMbEiSnVj1xYQUndWYGzPwEMJ

# === Filesystem layout ===
# Where the auctioneer registry, bidder state, and bidder JSONL streams live.
# Defaults to <repo>/scripts/. On Fly we point this at the persistent volume.
# SEALDEX_STATE_DIR=

# Where keypair JSON files live (seller.json, bidder1.json, bidder2.json).
# Defaults to <repo>/.keys/.
# SEALDEX_KEYS_DIR=

# Override the seed-inventory path for the auctioneer (defaults to
# <repo>/scripts/seed-inventory.json).
# SEALDEX_INVENTORY_PATH=

# Override the IDL path for the frontend (defaults to
# <repo>/target/idl/sealdex_auction.json).
# SEALDEX_IDL_PATH=

# Public registry feed for third-party bidder agents. When unset, the bidder
# reads $SEALDEX_STATE_DIR/auction-registry.json directly (used when the
# bidder runs alongside the auctioneer in the same container).
# SEALDEX_REGISTRY_URL=https://sealdex.fly.dev/api/auctions

# SPL mint used for create_auction. SystemProgram::ID acts as a placeholder
# for the demo where settlement amounts are notional.
# SEALDEX_PAYMENT_MINT=11111111111111111111111111111111

# === Frontend ===
# Origin baked into robots.txt, sitemap.xml, and OG meta. Defaults to the
# Fly deployment; override for local previews.
# NEXT_PUBLIC_SITE_URL=https://sealdex.fly.dev

# === Private Payments API (escrow agent only) ===
# Optional. Without these the escrow agent logs a stub instead of moving
# funds.
# PRIVATE_PAYMENTS_API_BASE=
# PRIVATE_PAYMENTS_API_KEY=
