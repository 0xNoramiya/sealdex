# Secrets / wallets
.env
.env.*
!.env.example
.keys/
*.keypair.json
keypair*.json
target/deploy/*-keypair.json

# Anchor / Rust — ignore everything in target/ except the public IDL so
# the frontend / agents work without the Solana toolchain installed.
target/*
!target/idl/
.anchor/
test-ledger/
Cargo.lock

# Node
node_modules/
.next/
dist/
build/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
.claude/
*.swp
*.swo

# Logs
logs/
*.log

# Local scratch
scratch/
tmp/
.cache/

# Runtime state written by agents (auctioneer registry, bidder state/streams)
scripts/auction-registry.json
scripts/bidder-*-state.json
scripts/bidder-*-stream.jsonl
scripts/.anchor/

# BYOK spawn registry — owner-scoped per-user data, never commit
scripts/spawns/
scripts/escrow-log.jsonl

# Transient bootstrap artefacts
Cargo.lock.backup

# Video — keep the composition source, exclude generated audio/renders
video/audio/
video/renders/
video/.hyperframes/
video/.thumbnails/
