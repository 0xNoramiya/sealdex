# Sealdex environment variables — copy to .env (which is gitignored)

# === Solana / MagicBlock ===
# Base devnet RPC (standard Solana devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# MagicBlock devnet TEE Ephemeral Rollup endpoint
EPHEMERAL_RPC_URL=https://devnet-tee.magicblock.app

# TEE validator pubkey (devnet) — required when delegating accounts
TEE_VALIDATOR_PUBKEY=MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo

# Permission / Delegation programs
PERMISSION_PROGRAM_ID=ACLseoPoyC3cBqoUtkbjZ4aDrkurZW86v19pXz2XQnp1
DELEGATION_PROGRAM_ID=DELeGGvXpWV2fqJUhqcF5ZSYMS4JTLjteaAMARRSaeSh

# === Wallet keypaths (paths only — files live under .keys/ which is gitignored) ===
SELLER_KEYPAIR=.keys/seller.json
BIDDER1_KEYPAIR=.keys/bidder1.json
BIDDER2_KEYPAIR=.keys/bidder2.json
ESCROW_KEYPAIR=.keys/escrow.json

# === Anthropic ===
ANTHROPIC_API_KEY=

# === Private Payments API ===
PRIVATE_PAYMENTS_API_BASE=
PRIVATE_PAYMENTS_API_KEY=

# === Demo SPL mint (created by scripts/setup-demo-wallets.ts) ===
DEMO_MINT=
